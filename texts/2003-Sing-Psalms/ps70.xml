                    <seg type="syl" n="6">va-</seg>
                    <seg type="syl" n="7">tion</seg>
                </l>
                <l>
                    <seg type="syl" n="1">say,</seg>
                    <seg type="syl" n="2">“To</seg>
                    <seg type="syl" n="3">o-</seg>
                    <seg type="syl" n="4">ur</seg>
                    <seg type="syl" n="5">God</seg>
                    <seg type="syl" n="6">be</seg>
                    <seg type="syl" n="7" cert="low">praise!”</seg>
                </l>
                <l>
                    <seg type="syl" n="1" cert="low">5. Yet</seg>
                    <seg type="syl" n="2" cert="low">I</seg>
                    <seg type="syl" n="3" cert="low">am</seg>
                    <seg type="syl" n="4" cert="low">poor</seg>
                    <seg type="syl" n="5" cert="low">and</seg>
                    <seg type="syl" n="6" cert="low">nee-</seg>
                    <seg type="syl" n="7" cert="low">dy;</seg>
                </l>
                <l>
                    <seg type="syl" n="1" cert="low">come</seg>
                    <seg type="syl" n="2" cert="low">quick-</seg>
                    <seg type="syl" n="3" cert="low">ly,</seg>
                    <seg type="syl" n="4" cert="low">God,</seg>
                    <seg type="syl" n="5" cert="low">I</seg>
                    <seg type="syl" n="6" cert="low">pray.</seg>
                </l>
                <l>
                    <seg type="syl" n="1" cert="low">You</seg>
                    <seg type="syl" n="2" cert="low">are</seg>
                    <seg type="syl" n="3" cert="low">my</seg>
                    <seg type="syl" n="4" cert="low">help</seg>
                    <seg type="syl" n="5" cert="low">and</seg>
                    <seg type="syl" n="6" cert="low">saviour;</seg>
                </l>
                <l>
                    <seg type="syl" n="1" cert="low">O</seg>
                    <seg type="syl" n="2" cert="low">LORD,</seg>
                    <seg type="syl" n="3" cert="low">do</seg>
                    <seg type="syl" n="4" cert="low">not</seg>
                    <seg type="syl" n="5" cert="low">de-</seg>
                    <seg type="syl" n="6" cert="low">lay.</seg>
                </l>
