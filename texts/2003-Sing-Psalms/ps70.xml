<text>
    <body>
        <div type="poem" met="7.6.7.6. D">
            <lg type="verse" n="1-3">
                <l>
                    <seg type="syl" n="1">1. Make</seg>
                    <seg type="syl" n="2">haste,</seg>
                    <seg type="syl" n="3">O</seg>
                    <seg type="syl" n="4">God,</seg>
                    <seg type="syl" n="5">to</seg>
                    <seg type="syl" n="6">save</seg>
                    <seg type="syl" n="7">me;</seg>
                </l>
                <l>
                    <seg type="syl" n="1">O</seg>
                    <seg type="syl" n="2">LORD,</seg>
                    <seg type="syl" n="3">come</seg>
                    <seg type="syl" n="4">to</seg>
                    <seg type="syl" n="5">my</seg>
                    <seg type="syl" n="6">aid.</seg>
                </l>
                <l>
                    <seg type="syl" n="1">2. May</seg>
                    <seg type="syl" n="2">those</seg>
                    <seg type="syl" n="3">who</seg>
                    <seg type="syl" n="4">seek</seg>
                    <seg type="syl" n="5">to</seg>
                    <seg type="syl" n="6">kill</seg>
                    <seg type="syl" n="7">me</seg>
                </l>
                <l>
                    <seg type="syl" n="1">be</seg>
                    <seg type="syl" n="2">ut-</seg>
                    <seg type="syl" n="3">ter-</seg>
                    <seg type="syl" n="4">ly</seg>
                    <seg type="syl" n="5">dis-</seg>
                    <seg type="syl" n="6">mayed.</seg>
                </l>
                <l>
                    <seg type="syl" n="1">May</seg>
                    <seg type="syl" n="2">all</seg>
                    <seg type="syl" n="3">who</seg>
                    <seg type="syl" n="4">seek</seg>
                    <seg type="syl" n="5">my</seg>
                    <seg type="syl" n="6">ru-</seg>
                    <seg type="syl" n="7">in</seg>
                </l>
                <l>
                    <seg type="syl" n="1">be</seg>
                    <seg type="syl" n="2">turned</seg>
                    <seg type="syl" n="3">back</seg>
                    <seg type="syl" n="4">in</seg>
                    <seg type="syl" n="5">dis-</seg>
                    <seg type="syl" n="6">grace,</seg>
                </l>
                <l>
                    <seg type="syl" n="1">3. And</seg>
                    <seg type="syl" n="2">may</seg>
                    <seg type="syl" n="3">all</seg>
                    <seg type="syl" n="4">those</seg>
                    <seg type="syl" n="5">who</seg>
                    <seg type="syl" n="6">mock</seg>
                    <seg type="syl" n="7">me</seg>
                </l>
                <l>
                    <seg type="syl" n="1">with</seg>
                    <seg type="syl" n="2">shame</seg>
                    <seg type="syl" n="3">their</seg>
                    <seg type="syl" n="4">steps</seg>
                    <seg type="syl" n="5">re-</seg>
                    <seg type="syl" n="6">trace.</seg>
                </l>
            </lg>
            <lg type="verse" n="4-5">
                <l>
                    <seg type="syl" n="1">4. But</seg>
                    <seg type="syl" n="2">may</seg>
                    <seg type="syl" n="3">all</seg>
                    <seg type="syl" n="4">those</seg>
                    <seg type="syl" n="5">who</seg>
                    <seg type="syl" n="6">seek</seg>
                    <seg type="syl" n="7">you</seg>
                </l>
                <l>
                    <seg type="syl" n="1">re-</seg>
                    <seg type="syl" n="2">joice</seg>
                    <seg type="syl" n="3">in</seg>
                    <seg type="syl" n="4">you</seg>
                    <seg type="syl" n="5">al-</seg>
                    <seg type="syl" n="6">ways;</seg>
                </l>
                <l>
                    <seg type="syl" n="1">May</seg>
                    <seg type="syl" n="2">those</seg>
                    <seg type="syl" n="3">who</seg>
                    <seg type="syl" n="4">love</seg>
                    <seg type="syl" n="5">sal-</seg>
                    <seg type="syl" n="6">va-</seg>
                    <seg type="syl" n="7">tion</seg>
                </l>
                <l>
                    <seg type="syl" n="1">say,</seg>
                    <seg type="syl" n="2">“To</seg>
                    <seg type="syl" n="3">our</seg>
                    <seg type="syl" n="4">God</seg>
                    <seg type="syl" n="5">be</seg>
                    <seg type="syl" n="6">praise!”</seg>
                </l>
                <l>
                    <seg type="syl" n="1">5. Yet</seg>
                    <seg type="syl" n="2">I</seg>
                    <seg type="syl" n="3">am</seg>
                    <seg type="syl" n="4">poor</seg>
                    <seg type="syl" n="5">and</seg>
                    <seg type="syl" n="6">nee-</seg>
                    <seg type="syl" n="7">dy;</seg>
                </l>
                <l>
                    <seg type="syl" n="1">come</seg>
                    <seg type="syl" n="2">quick-</seg>
                    <seg type="syl" n="3">ly,</seg>
                    <seg type="syl" n="4">God,</seg>
                    <seg type="syl" n="5">I</seg>
                    <seg type="syl" n="6">pray.</seg>
                </l>
                <l>
                    <seg type="syl" n="1">You</seg>
                    <seg type="syl" n="2">are</seg>
                    <seg type="syl" n="3">my</seg>
                    <seg type="syl" n="4">help</seg>
                    <seg type="syl" n="5">and</seg>
                    <seg type="syl" n="6">sa-</seg>
                    <seg type="syl" n="7">viour;</seg>
                </l>
                <l>
                    <seg type="syl" n="1">O</seg>
                    <seg type="syl" n="2">LORD,</seg>
                    <seg type="syl" n="3">do</seg>
                    <seg type="syl" n="4">not</seg>
                    <seg type="syl" n="5">de-</seg>
                    <seg type="syl" n="6">lay.</seg>
                </l>
            </lg>
