                    <seg type="syl" n="2">ut-</seg>
                    <seg type="syl" n="3">ter-</seg>
                    <seg type="syl" n="4">ly</seg>
                    <seg type="syl" n="5">dis-</seg>
                    <seg type="syl" n="6">mayed.</seg>
                </l>
                <l>
                    <seg type="syl" n="1" cert="low">May</seg>
                    <seg type="syl" n="2" cert="low">all</seg>
                    <seg type="syl" n="3" cert="low">who</seg>
                    <seg type="syl" n="4" cert="low">seek</seg>
                    <seg type="syl" n="5" cert="low">my</seg>
                    <seg type="syl" n="6" cert="low">ru-</seg>
                    <seg type="syl" n="7" cert="low">in</seg>
                </l>
                <l>
                    <seg type="syl" n="1" cert="low">be</seg>
                    <seg type="syl" n="2" cert="low">turned</seg>
                    <seg type="syl" n="3" cert="low">back</seg>
                    <seg type="syl" n="4" cert="low">in</seg>
                    <seg type="syl" n="5" cert="low">dis-</seg>
                    <seg type="syl" n="6" cert="low">grace,</seg>
                </l>
                <l>
                    <seg type="syl" n="1" cert="low">3. And</seg>
                    <seg type="syl" n="2" cert="low">may</seg>
                    <seg type="syl" n="3" cert="low">all</seg>
                    <seg type="syl" n="4" cert="low">those</seg>
                    <seg type="syl" n="5" cert="low">who</seg>
                    <seg type="syl" n="6" cert="low">mock</seg>
                    <seg type="syl" n="7" cert="low">me</seg>
                </l>
                <l>
                    <seg type="syl" n="1" cert="low">with</seg>
                    <seg type="syl" n="2" cert="low">shame</seg>
                    <seg type="syl" n="3" cert="low">their</seg>
                    <seg type="syl" n="4" cert="low">steps</seg>
                    <seg type="syl" n="5" cert="low">re-</seg>
                    <seg type="syl" n="6" cert="low">trace.</seg>
                </l>
            </lg>
            <lg type="verse" n="4-5" cert="low">
                <l>
