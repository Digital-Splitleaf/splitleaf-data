                    <seg type="syl" n="2">maids</seg>
                    <seg type="syl" n="3">be-</seg>
                    <seg type="syl" n="4">fore</seg>
                    <seg type="syl" n="5">their</seg>
                    <seg type="syl" n="6">mis-</seg>
                    <seg type="syl" n="7">tress</seg>
                    <seg type="syl" n="8">stand,</seg>
                </l>
                <l>
                    <seg type="syl" n="1">So</seg>
                    <seg type="syl" n="2">to</seg>
                    <seg type="syl" n="3">the</seg>
                    <seg type="syl" n="4">LORD</seg>
                    <seg type="syl" n="5">our</seg>
                    <seg type="syl" n="6">eyes</seg>
                    <seg type="syl" n="7">we</seg>
                    <seg type="syl" n="8">raise</seg>
                </l>
                <l>
                    <seg type="syl" n="1">Un-</seg>
                    <seg type="syl" n="2">til</seg>
                    <seg type="syl" n="3">his</seg>
                    <seg type="syl" n="4">mer-</seg>
                    <seg type="syl" n="5">cy</seg>
                    <seg type="syl" n="6">he</seg>
                    <seg type="syl" n="7">dis-</seg>
                    <seg type="syl" n="8">plays.</seg>
                </l>
            </lg>
            <lg type="verse" n="3-4">
                <l>
                    <seg type="syl" n="1">3. O</seg>
                    <seg type="syl" n="2">LORD</seg>
                    <seg type="syl" n="3">our</seg>
                    <seg type="syl" n="4">God,</seg>
                    <seg type="syl" n="5">your</seg>
                    <seg type="syl" n="6">mer-</seg>
                    <seg type="syl" n="7">cy</seg>
                    <seg type="syl" n="8">show;</seg>
                </l>
                <l>
                    <seg type="syl" n="1">Take</seg>
                    <seg type="syl" n="2">pi-</seg>
                    <seg type="syl" n="3">ty,</seg>
                    <seg type="syl" n="4">LORD,</seg>
                    <seg type="syl" n="5">on</seg>
                    <seg type="syl" n="6">us</seg>
                    <seg type="syl" n="7">be-</seg>
                    <seg type="syl" n="8">low.</seg>
                </l>
                <l>
                    <seg type="syl" n="1">For</seg>
                    <seg type="syl" n="2">scorn</seg>
                    <seg type="syl" n="3">your</seg>
                    <seg type="syl" n="4">peo-</seg>
                    <seg type="syl" n="5">ple</seg>
                    <seg type="syl" n="6">all</seg>
                    <seg type="syl" n="7">have</seg>
                    <seg type="syl" n="8">known;</seg>
                </l>
                <l>
                    <seg type="syl" n="1">4. Our</seg>
                    <seg type="syl" n="2">foes'</seg>
                    <seg type="syl" n="3">con-</seg>
                    <seg type="syl" n="4">tempt</seg>
                    <seg type="syl" n="5">has</seg>
                    <seg type="syl" n="6">made</seg>
                    <seg type="syl" n="7">us</seg>
                    <seg type="syl" n="8">groan.</seg>
                </l>
                <l>
                    <seg type="syl" n="1">The</seg>
                    <seg type="syl" n="2">proud</seg>
                    <seg type="syl" n="3">have</seg>
                    <seg type="syl" n="4">cov-</seg>
                    <seg type="syl" n="5">ered</seg>
                    <seg type="syl" n="6">us</seg>
                    <seg type="syl" n="7">with</seg>
                    <seg type="syl" n="8">shame;</seg>
                </l>
                <l>
                    <seg type="syl" n="1">With</seg>
                    <seg type="syl" n="2">in-</seg>
                    <seg type="syl" n="3">so-</seg>
                    <seg type="syl" n="4">lence</seg>
                    <seg type="syl" n="5">they</seg>
                    <seg type="syl" n="6">mock</seg>
                    <seg type="syl" n="7">our</seg>
                    <seg type="syl" n="8">name.</seg>
                </l>
