<text>
    <body>
        <div type="poem" met="8.8.8.8.8.8.">
            <lg type="verse" n="1-2">
                <l>
                    <seg type="syl" n="1">1. To</seg>
                    <seg type="syl" n="2">you,</seg>
                    <seg type="syl" n="3">O</seg>
                    <seg type="syl" n="4">LORD,</seg>
                    <seg type="syl" n="5">I</seg>
                    <seg type="syl" n="6">lift</seg>
                    <seg type="syl" n="7">my</seg>
                    <seg type="syl" n="8">eyes,</seg>
                </l>
                <l>
                    <seg type="syl" n="1">The</seg>
                    <seg type="syl" n="2">God</seg>
                    <seg type="syl" n="3">en-</seg>
                    <seg type="syl" n="4">throned</seg>
                    <seg type="syl" n="5">a-</seg>
                    <seg type="syl" n="6">bove</seg>
                    <seg type="syl" n="7">the</seg>
                    <seg type="syl" n="8">skies.</seg>
                </l>
                <l>
                    <seg type="syl" n="1">2. As</seg>
                    <seg type="syl" n="2">ser-</seg>
                    <seg type="syl" n="3">vants</seg>
                    <seg type="syl" n="4">watch</seg>
                    <seg type="syl" n="5">their</seg>
                    <seg type="syl" n="6">mas-</seg>
                    <seg type="syl" n="7">ter’s</seg>
                    <seg type="syl" n="8">hand</seg>
                </l>
                <l>
