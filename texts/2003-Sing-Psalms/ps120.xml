                    <seg type="syl" n="6">live</seg>
                    <seg type="syl" n="7">in</seg>
                    <seg type="syl" n="8">Me-</seg>
                    <seg type="syl" n="9">shech’s</seg>
                    <seg type="syl" n="10">land</seg>
                </l>
                <l>
                    <seg type="syl" n="1">In</seg>
                    <seg type="syl" n="2">Ke-</seg>
                    <seg type="syl" n="3">dar’s</seg>
                    <seg type="syl" n="4">tents,</seg>
                    <seg type="syl" n="5">a-</seg>
                    <seg type="syl" n="6">mong</seg>
                    <seg type="syl" n="7">my</seg>
                    <seg type="syl" n="8">e-</seg>
                    <seg type="syl" n="9">ne-</seg>
                    <seg type="syl" n="10">mies!</seg>
                </l>
                <l>
                    <seg type="syl" n="1">6. With</seg>
                    <seg type="syl" n="2">peo-</seg>
                    <seg type="syl" n="3">ple</seg>
                    <seg type="syl" n="4">lov-</seg>
                    <seg type="syl" n="5">ing</seg>
                    <seg type="syl" n="6">strife</seg>
                    <seg type="syl" n="7">I’ve</seg>
                    <seg type="syl" n="8">lived</seg>
                    <seg type="syl" n="9">too</seg>
                    <seg type="syl" n="10">long;</seg>
                </l>
                <l>
                    <seg type="syl" n="1">7. They</seg>
                    <seg type="syl" n="2">are</seg>
                    <seg type="syl" n="3">for</seg>
                    <seg type="syl" n="4">war,</seg>
                    <seg type="syl" n="5">but</seg>
