                    <seg type="syl" n="8">ceit-</seg>
                    <seg type="syl" n="9">ful</seg>
                    <seg type="syl" n="10">tongue?</seg>
                </l>
                <l>
                    <seg type="syl" n="1">What</seg>
                    <seg type="syl" n="2">more</seg>
                    <seg type="syl" n="3">be-</seg>
                    <seg type="syl" n="4">sides</seg>
                    <seg type="syl" n="5">will</seg>
