<text>
    <body>
        <div type="poem" met="8.8.8.8. anapaestic">
            <lg type="verse" n="1-2">
                <l>
                    <seg type="syl" n="1">1. I</seg>
                    <seg type="syl" n="2">lift</seg>
                    <seg type="syl" n="3">up</seg>
                    <seg type="syl" n="4">my</seg>
                    <seg type="syl" n="5">eyes</seg>
                    <seg type="syl" n="6">to</seg>
                    <seg type="syl" n="7">the</seg>
                    <seg type="syl" n="8">hills—</seg>
                </l>
                <l>
                    <seg type="syl" n="1">Where</seg>
                    <seg type="syl" n="2">am</seg>
                    <seg type="syl" n="3">I</seg>
                    <seg type="syl" n="4">to</seg>
                    <seg type="syl" n="5">look</seg>
                    <seg type="syl" n="6">for</seg>
                    <seg type="syl" n="7">my</seg>
                    <seg type="syl" n="8">aid?</seg>
                </l>
                <l>
                    <seg type="syl" n="1">2. My</seg>
                    <seg type="syl" n="2">help</seg>
                    <seg type="syl" n="3">comes</seg>
                    <seg type="syl" n="4">to</seg>
                    <seg type="syl" n="5">me</seg>
                    <seg type="syl" n="6">from</seg>
                    <seg type="syl" n="7">the</seg>
                    <seg type="syl" n="8">LORD</seg>
                </l>
                <l>
                    <seg type="syl" n="1">By</seg>
                    <seg type="syl" n="2">whom</seg>
                    <seg type="syl" n="3">earth</seg>
                    <seg type="syl" n="4">and</seg>
                    <seg type="syl" n="5">heav-</seg>
                    <seg type="syl" n="6">en</seg>
                    <seg type="syl" n="7">were</seg>
                    <seg type="syl" n="8">made.</seg>
                </l>
            </lg>
            <lg type="verse" n="3-4">
                <l>
                    <seg type="syl" n="1">3. Your</seg>
                    <seg type="syl" n="2">foot</seg>
                    <seg type="syl" n="3">he</seg>
                    <seg type="syl" n="4">will</seg>
                    <seg type="syl" n="5">not</seg>
                    <seg type="syl" n="6">leave</seg>
                    <seg type="syl" n="7">to</seg>
                    <seg type="syl" n="8">slide—</seg>
                </l>
                <l>
                    <seg type="syl" n="1">His</seg>
                    <seg type="syl" n="2">watch</seg>
                    <seg type="syl" n="3">o-</seg>
                    <seg type="syl" n="4">ver</seg>
                    <seg type="syl" n="5">you</seg>
                    <seg type="syl" n="6">he</seg>
                    <seg type="syl" n="7">will</seg>
                    <seg type="syl" n="8">keep.</seg>
                </l>
                <l>
                    <seg type="syl" n="1">4. The</seg>
                    <seg type="syl" n="2">LORD</seg>
                    <seg type="syl" n="3">o-</seg>
                    <seg type="syl" n="4">ver</seg>
                    <seg type="syl" n="5">Is-</seg>
                    <seg type="syl" n="6">r’el</seg>
                    <seg type="syl" n="7">keeps</seg>
                    <seg type="syl" n="8">watch,</seg>
                </l>
                <l>
                    <seg type="syl" n="1">And</seg>
                    <seg type="syl" n="2">he</seg>
                    <seg type="syl" n="3">will</seg>
                    <seg type="syl" n="4">not</seg>
                    <seg type="syl" n="5">slum-</seg>
                    <seg type="syl" n="6">ber</seg>
                    <seg type="syl" n="7">or</seg>
                    <seg type="syl" n="8">sleep.</seg>
                </l>
            </lg>
            <lg type="verse" n="5-6">
                <l>
                    <seg type="syl" n="1">5. The</seg>
                    <seg type="syl" n="2">LORD</seg>
                    <seg type="syl" n="3">will</seg>
                    <seg type="syl" n="4">keep</seg>
                    <seg type="syl" n="5">watch</seg>
                    <seg type="syl" n="6">o-</seg>
                    <seg type="syl" n="7">ver</seg>
                    <seg type="syl" n="8">you—</seg>
                </l>
                <l>
                    <seg type="syl" n="1">Your</seg>
                    <seg type="syl" n="2">shade</seg>
                    <seg type="syl" n="3">from</seg>
                    <seg type="syl" n="4">the</seg>
                    <seg type="syl" n="5">heat</seg>
                    <seg type="syl" n="6">and</seg>
                    <seg type="syl" n="7">the</seg>
                    <seg type="syl" n="8">light.</seg>
                </l>
                <l>
                    <seg type="syl" n="1">6. The</seg>
                    <seg type="syl" n="2">sun</seg>
                    <seg type="syl" n="3">will</seg>
                    <seg type="syl" n="4">not</seg>
                    <seg type="syl" n="5">harm</seg>
                    <seg type="syl" n="6">you</seg>
                    <seg type="syl" n="7">by</seg>
                    <seg type="syl" n="8">day;</seg>
                </l>
                <l>
                    <seg type="syl" n="1">The</seg>
                    <seg type="syl" n="2">moon</seg>
                    <seg type="syl" n="3">will</seg>
                    <seg type="syl" n="4">not</seg>
                    <seg type="syl" n="5">harm</seg>
                    <seg type="syl" n="6">you</seg>
                    <seg type="syl" n="7">by</seg>
                    <seg type="syl" n="8">night.</seg>
                </l>
            </lg>
            <lg type="verse" n="7-8">
                <l>
                    <seg type="syl" n="1">7. The</seg>
                    <seg type="syl" n="2">LORD</seg>
                    <seg type="syl" n="3">will</seg>
                    <seg type="syl" n="4">pro-</seg>
                    <seg type="syl" n="5">tect</seg>
                    <seg type="syl" n="6">you</seg>
                    <seg type="syl" n="7">from</seg>
                    <seg type="syl" n="8">harm—</seg>
                </l>
                <l>
                    <seg type="syl" n="1">Your</seg>
                    <seg type="syl" n="2">life</seg>
                    <seg type="syl" n="3">he</seg>
                    <seg type="syl" n="4">will</seg>
                    <seg type="syl" n="5">ev-</seg>
                    <seg type="syl" n="6">er</seg>
                    <seg type="syl" n="7">de-</seg>
                    <seg type="syl" n="8">fend.</seg>
                </l>
                <l>
                    <seg type="syl" n="1">8. He’ll</seg>
                    <seg type="syl" n="2">guard</seg>
                    <seg type="syl" n="3">ev-</seg>
                    <seg type="syl" n="4">e-</seg>
                    <seg type="syl" n="5">ry</seg>
                    <seg type="syl" n="6">step</seg>
                    <seg type="syl" n="7">that</seg>
                    <seg type="syl" n="8">you</seg>
                    <seg type="syl" n="9">take</seg>
                </l>
                <l>
                    <seg type="syl" n="1">Both</seg>
                    <seg type="syl" n="2">now</seg>
                    <seg type="syl" n="3">and</seg>
                    <seg type="syl" n="4">for</seg>
                    <seg type="syl" n="5">days</seg>
                    <seg type="syl" n="6">with-</seg>
                    <seg type="syl" n="7">out</seg>
                    <seg type="syl" n="8">end.</seg>
                </l>
            </lg>
        </div>
    </body>
</text>
