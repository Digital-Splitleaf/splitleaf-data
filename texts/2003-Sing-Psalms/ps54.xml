                    <seg type="syl" n="2">lis-</seg>
                    <seg type="syl" n="3">ten</seg>
                    <seg type="syl" n="4">to</seg>
                    <seg type="syl" n="5">my</seg>
                    <seg type="syl" n="6">plea.</seg>
                </l>
            </lg>
            <lg type="verse" n="3">
                <l>
