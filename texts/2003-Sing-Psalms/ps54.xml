                    <seg type="syl" n="2">stran-</seg>
                    <seg type="syl" n="3">gers</seg>
                    <seg type="syl" n="4">are</seg>
                    <seg type="syl" n="5">at-</seg>
                    <seg type="syl" n="6">tack-</seg>
                    <seg type="syl" n="7">ing</seg>
                    <seg type="syl" n="8">me;</seg>
                </l>
                <l>
                    <seg type="syl" n="1">the</seg>
                    <seg type="syl" n="2">ruth-</seg>
                    <seg type="syl" n="3">less</seg>
                    <seg type="syl" n="4">seek</seg>
                    <seg type="syl" n="5">my</seg>
                    <seg type="syl" n="6">life,</seg>
                </l>
                <l>
                    <seg type="syl" n="1">For</seg>
                    <seg type="syl" n="2">they</seg>
                    <seg type="syl" n="3">have</seg>
                    <seg type="syl" n="4">no</seg>
                    <seg type="syl" n="5">re-</seg>
                    <seg type="syl" n="6">gard</seg>
                    <seg type="syl" n="7">for</seg>
                    <seg type="syl" n="8">God</seg>
                </l>
                <l>
                    <seg type="syl" n="1">and</seg>
                    <seg type="syl" n="2">al-</seg>
                    <seg type="syl" n="3">ways</seg>
                    <seg type="syl" n="4">stir</seg>
                    <seg type="syl" n="5">up</seg>
                    <seg type="syl" n="6">strife.</seg>
                </l>
            </lg>
            <lg type="verse" n="4-5">
                <l>
                    <seg type="syl" n="1">4. Con-</seg>
                    <seg type="syl" n="2">sid-</seg>
                    <seg type="syl" n="3">er</seg>
                    <seg type="syl" n="4">this:</seg>
                    <seg type="syl" n="5">God</seg>
                    <seg type="syl" n="6">is</seg>
                    <seg type="syl" n="7">my</seg>
                    <seg type="syl" n="8">help;</seg>
                </l>
                <l>
                    <seg type="syl" n="1">the</seg>
                    <seg type="syl" n="2">Lord</seg>
                    <seg type="syl" n="3">up-</seg>
                    <seg type="syl" n="4">holds</seg>
                    <seg type="syl" n="5">my</seg>
                    <seg type="syl" n="6">way.</seg>
                </l>
                <l>
                    <seg type="syl" n="1">5. In</seg>
                    <seg type="syl" n="2">faith-</seg>
                    <seg type="syl" n="3">ful-</seg>
                    <seg type="syl" n="4">ness</seg>
                    <seg type="syl" n="5">de-</seg>
                    <seg type="syl" n="6">stroy</seg>
                    <seg type="syl" n="7">my</seg>
                    <seg type="syl" n="8">foes;</seg>
                </l>
                <l>
                    <seg type="syl" n="1">their</seg>
                    <seg type="syl" n="2">slan-</seg>
                    <seg type="syl" n="3">der,</seg>
                    <seg type="syl" n="4">Lord,</seg>
                    <seg type="syl" n="5">re-</seg>
                    <seg type="syl" n="6">pay.</seg>
                </l>
            </lg>
            <lg type="verse" n="6">
                <l>
                    <seg type="syl" n="1">6. I’ll</seg>
                    <seg type="syl" n="2">bring</seg>
                    <seg type="syl" n="3">a</seg>
                    <seg type="syl" n="4">sac-</seg>
                    <seg type="syl" n="5">ri-</seg>
                    <seg type="syl" n="6">fice</seg>
                    <seg type="syl" n="7">to</seg>
                    <seg type="syl" n="8">you,</seg>
                </l>
                <l>
                    <seg type="syl" n="1">a</seg>
                    <seg type="syl" n="2">free-</seg>
                    <seg type="syl" n="3">will</seg>
                    <seg type="syl" n="4">of-</seg>
                    <seg type="syl" n="5">fer-</seg>
                    <seg type="syl" n="6">ing;</seg>
                </l>
                <l>
                    <seg type="syl" n="1">Be-</seg>
                    <seg type="syl" n="2">cause</seg>
                    <seg type="syl" n="3">your</seg>
                    <seg type="syl" n="4">name,</seg>
                    <seg type="syl" n="5">O</seg>
                    <seg type="syl" n="6">LORD,</seg>
                    <seg type="syl" n="7">is</seg>
                    <seg type="syl" n="8">good,</seg>
                </l>
                <l>
                    <seg type="syl" n="1">your</seg>
                    <seg type="syl" n="2">prais-</seg>
                    <seg type="syl" n="3">es</seg>
                    <seg type="syl" n="4">I</seg>
                    <seg type="syl" n="5">will</seg>
                    <seg type="syl" n="6">sing.</seg>
                </l>
            </lg>
            <lg type="verse" n="7">
                <l>
                    <seg type="syl" n="1">7. For</seg>
                    <seg type="syl" n="2">you,</seg>
                    <seg type="syl" n="3">O</seg>
                    <seg type="syl" n="4">LORD,</seg>
                    <seg type="syl" n="5">have</seg>
                    <seg type="syl" n="6">res-</seg>
                    <seg type="syl" n="7">cued</seg>
                    <seg type="syl" n="8">me</seg>
                </l>
                <l>
                    <seg type="syl" n="1">from</seg>
                    <seg type="syl" n="2">my</seg>
                    <seg type="syl" n="3">dis-</seg>
                    <seg type="syl" n="4">tress</seg>
                    <seg type="syl" n="5">and</seg>
                    <seg type="syl" n="6">woe;</seg>
                </l>
                <l>
                    <seg type="syl" n="1">My</seg>
                    <seg type="syl" n="2">eyes</seg>
                    <seg type="syl" n="3">have</seg>
                    <seg type="syl" n="4">looked</seg>
                    <seg type="syl" n="5">in</seg>
                    <seg type="syl" n="6">vic-</seg>
                    <seg type="syl" n="7">to-</seg>
                    <seg type="syl" n="8">ry</seg>
                </l>
                <l>
                    <seg type="syl" n="1">up-</seg>
                    <seg type="syl" n="2">on</seg>
                    <seg type="syl" n="3">my</seg>
                    <seg type="syl" n="4">cru-</seg>
                    <seg type="syl" n="5">el</seg>
                    <seg type="syl" n="6">foe.</seg>
                </l>
            </lg>
