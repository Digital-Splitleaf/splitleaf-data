<text>
    <body>
        <div type="poem" met="8.6.8.6.">
            <lg type="verse" n="1-2">
                <l>
                    <seg type="syl" n="1">1. Save</seg>
                    <seg type="syl" n="2">me,</seg>
                    <seg type="syl" n="3">O</seg>
                    <seg type="syl" n="4">God,</seg>
                    <seg type="syl" n="5">by</seg>
                    <seg type="syl" n="6">your</seg>
                    <seg type="syl" n="7">great</seg>
                    <seg type="syl" n="8">name;</seg>
                </l>
                <l>
                    <seg type="syl" n="1">with</seg>
                    <seg type="syl" n="2">pow’r</seg>
                    <seg type="syl" n="3">de-</seg>
                    <seg type="syl" n="4">liv-</seg>
                    <seg type="syl" n="5">er</seg>
                    <seg type="syl" n="6">me.</seg>
                </l>
                <l>
                    <seg type="syl" n="1">2. Hear,</seg>
                    <seg type="syl" n="2">O</seg>
                    <seg type="syl" n="3">my</seg>
                    <seg type="syl" n="4">God,</seg>
                    <seg type="syl" n="5">the</seg>
                    <seg type="syl" n="6">words</seg>
                    <seg type="syl" n="7">I</seg>
                    <seg type="syl" n="8">speak</seg>
                </l>
                <l>
