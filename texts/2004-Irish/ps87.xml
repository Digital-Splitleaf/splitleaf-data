                    <seg type="syl" n="2">know-</seg>
                    <seg type="syl" n="3">ing</seg>
                    <seg type="syl" n="4">me,</seg>
                    <seg type="syl" n="5">the</seg>
                    <seg type="syl" n="6">Lord.</seg>
                </l>
            </lg>
            <lg type="verse" n="3">
