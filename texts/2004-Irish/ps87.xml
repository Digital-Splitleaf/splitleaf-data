                </l>
                <l>
                    <seg type="syl" n="1">'This</seg>
                    <seg type="syl" n="2">man</seg>
                    <seg type="syl" n="3">was</seg>
                    <seg type="syl" n="4">born</seg>
                    <seg type="syl" n="5">there,</seg>
                    <seg type="syl" n="6">too.'</seg>
                </l>
                <l>
                    <seg type="syl" n="1">All</seg>
                    <seg type="syl" n="2">sin-</seg>
                    <seg type="syl" n="3">gers,</seg>
                    <seg type="syl" n="4">play-</seg>
                    <seg type="syl" n="5">ers</seg>
                    <seg type="syl" n="6">say,</seg>
                    <seg type="syl" n="7">`My</seg>
                    <seg type="syl" n="8">springs</seg>
                </l>
                <l>
                    <seg type="syl" n="1">of</seg>
                    <seg type="syl" n="2">joy</seg>
                    <seg type="syl" n="3">are</seg>
                    <seg type="syl" n="4">all</seg>
                    <seg type="syl" n="5">in</seg>
                    <seg type="syl" n="6">you.'</seg>
