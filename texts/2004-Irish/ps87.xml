                    <seg type="syl" n="3">a</seg>
                    <seg type="syl" n="4">man</seg>
                    <seg type="syl" n="5">born</seg>
                    <seg type="syl" n="6">there.'</seg>
                </l>
            </lg>
            <lg type="verse" n="4">
                <l>
