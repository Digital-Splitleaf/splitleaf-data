                    <seg type="syl" n="2">LORD,</seg>
                    <seg type="syl" n="3">when</seg>
                    <seg type="syl" n="4">count-</seg>
                    <seg type="syl" n="5">ing</seg>
                    <seg type="syl" n="6">peo-</seg>
                    <seg type="syl" n="7">ples,</seg>
