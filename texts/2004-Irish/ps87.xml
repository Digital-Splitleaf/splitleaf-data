                    <seg type="syl" n="2">it</seg>
                    <seg type="syl" n="3">of</seg>
                    <seg type="syl" n="4">Z-</seg>
                    <seg type="syl" n="5">ion</seg>
                    <seg type="syl" n="6">will</seg>
                    <seg type="syl" n="7">be</seg>
                    <seg type="syl" n="8">said,</seg>
                </l>
                <l>
                    <seg type="syl" n="1">'This</seg>
                    <seg type="syl" n="2">man</seg>
                    <seg type="syl" n="3">and</seg>
                    <seg type="syl" n="4">that</seg>
                    <seg type="syl" n="5">man</seg>
                    <seg type="syl" n="6">there</seg>
                </l>
                <l>
                    <seg type="syl" n="1">was</seg>
                    <seg type="syl" n="2">born',</seg>
                    <seg type="syl" n="3">and</seg>
                    <seg type="syl" n="4">he</seg>
                    <seg type="syl" n="5">who</seg>
                    <seg type="syl" n="6">is</seg>
                    <seg type="syl" n="7">Most</seg>
                    <seg type="syl" n="8">High,</seg>
                </l>
                <l>
                    <seg type="syl" n="1">he</seg>
                    <seg type="syl" n="2">will</seg>
                    <seg type="syl" n="3">es-</seg>
                    <seg type="syl" n="4">tab-</seg>
                    <seg type="syl" n="5">lish</seg>
                    <seg type="syl" n="6">her.</seg>
                </l>
            </lg>
            <lg type="verse" n="5">
                <l>
