<text>
    <body>
        <div type="poem" met="8.6.8.6.">
            <lg type="verse" n="1">
                <l>
                    <seg type="syl" n="1">1. I</seg>
                    <seg type="syl" n="2">to</seg>
                    <seg type="syl" n="3">the</seg>
                    <seg type="syl" n="4">hills</seg>
                    <seg type="syl" n="5">will</seg>
                    <seg type="syl" n="6">lift</seg>
                    <seg type="syl" n="7">my</seg>
                    <seg type="syl" n="8">eyes.</seg>
                </l>
                <l>
                    <seg type="syl" n="1">From</seg>
                    <seg type="syl" n="2">where</seg>
                    <seg type="syl" n="3">will</seg>
                    <seg type="syl" n="4">come</seg>
                    <seg type="syl" n="5">my</seg>
                    <seg type="syl" n="6">aid?</seg>
                </l>
                <l>
                    <seg type="syl" n="1">My</seg>
                    <seg type="syl" n="2">aid</seg>
                    <seg type="syl" n="3">comes</seg>
                    <seg type="syl" n="4">on-</seg>
                    <seg type="syl" n="5">ly</seg>
                    <seg type="syl" n="6">from</seg>
                    <seg type="syl" n="7">the</seg>
                    <seg type="syl" n="8">LORD,</seg>
                </l>
                <l>
                    <seg type="syl" n="1">who</seg>
                    <seg type="syl" n="2">heav'n</seg>
                    <seg type="syl" n="3">and</seg>
                    <seg type="syl" n="4">earth</seg>
                    <seg type="syl" n="5">has</seg>
                    <seg type="syl" n="6">made.</seg>
                </l>
            </lg>
            <lg type="verse" n="2">
                <l>
                    <seg type="syl" n="1">2. Your</seg>
                    <seg type="syl" n="2">foot</seg>
                    <seg type="syl" n="3">he'll</seg>
                    <seg type="syl" n="4">not</seg>
                    <seg type="syl" n="5">let</seg>
                    <seg type="syl" n="6">slip,</seg>
                    <seg type="syl" n="7">nor</seg>
                    <seg type="syl" n="8">will</seg>
                </l>
                <l>
                    <seg type="syl" n="1">he</seg>
                    <seg type="syl" n="2">slum-</seg>
                    <seg type="syl" n="3">ber</seg>
                    <seg type="syl" n="4">who</seg>
                    <seg type="syl" n="5">you</seg>
                    <seg type="syl" n="6">keeps,</seg>
                </l>
                <l>
                    <seg type="syl" n="1">and</seg>
                    <seg type="syl" n="2">see!</seg>
                    <seg type="syl" n="3">He</seg>
                    <seg type="syl" n="4">who</seg>
                    <seg type="syl" n="5">keeps</seg>
                    <seg type="syl" n="6">Is-</seg>
                    <seg type="syl" n="7">r-</seg>
                    <seg type="syl" n="8">ael,</seg>
                </l>
                <l>
                    <seg type="syl" n="1">he</seg>
                    <seg type="syl" n="2">slum-</seg>
                    <seg type="syl" n="3">bers</seg>
                    <seg type="syl" n="4">not</seg>
                    <seg type="syl" n="5">nor</seg>
                    <seg type="syl" n="6">sleeps.</seg>
                </l>
            </lg>
            <lg type="verse" n="3">
                <l>
                    <seg type="syl" n="1">3. The</seg>
                    <seg type="syl" n="2">LORD</seg>
                    <seg type="syl" n="3">who</seg>
                    <seg type="syl" n="4">keeps</seg>
                    <seg type="syl" n="5">you</seg>
                    <seg type="syl" n="6">is</seg>
                    <seg type="syl" n="7">your</seg>
                    <seg type="syl" n="8">shade;</seg>
                </l>
                <l>
                    <seg type="syl" n="1">the</seg>
                    <seg type="syl" n="2">LORD's</seg>
                    <seg type="syl" n="3">at</seg>
                    <seg type="syl" n="4">your</seg>
                    <seg type="syl" n="5">right</seg>
                    <seg type="syl" n="6">arm.</seg>
                </l>
                <l>
                    <seg type="syl" n="1">The</seg>
                    <seg type="syl" n="2">sun</seg>
                    <seg type="syl" n="3">will</seg>
                    <seg type="syl" n="4">not</seg>
                    <seg type="syl" n="5">you</seg>
                    <seg type="syl" n="6">strike</seg>
                    <seg type="syl" n="7">by</seg>
                    <seg type="syl" n="8">day;</seg>
                </l>
                <l>
                    <seg type="syl" n="1">by</seg>
                    <seg type="syl" n="2">night</seg>
                    <seg type="syl" n="3">the</seg>
                    <seg type="syl" n="4">moon</seg>
                    <seg type="syl" n="5">won't</seg>
                    <seg type="syl" n="6">harm.</seg>
                </l>
            </lg>
            <lg type="verse" n="4" cert="low">
                <l>
                    <seg type="syl" n="1">4. The</seg>
                    <seg type="syl" n="2">LORD</seg>
                    <seg type="syl" n="3">from</seg>
                    <seg type="syl" n="4">e-</seg>
                    <seg type="syl" n="5">vil</seg>
                    <seg type="syl" n="6">will</seg>
                    <seg type="syl" n="7">pro-</seg>
                    <seg type="syl" n="8">tect;</seg>
                </l>
                <l>
                    <seg type="syl" n="1">he'll</seg>
                    <seg type="syl" n="2">sure-</seg>
                    <seg type="syl" n="3">ly</seg>
                    <seg type="syl" n="4">keep</seg>
                    <seg type="syl" n="5">your</seg>
                    <seg type="syl" n="6">soul.</seg>
                </l>
                <l>
                    <seg type="syl" n="1">The</seg>
                    <seg type="syl" n="2">LORD</seg>
                    <seg type="syl" n="3">your</seg>
                    <seg type="syl" n="4">go-</seg>
                    <seg type="syl" n="5">ing</seg>
                    <seg type="syl" n="6">out</seg>
                    <seg type="syl" n="7">and</seg>
                    <seg type="syl" n="8">in</seg>
                </l>
                <l>
                    <seg type="syl" n="1">will</seg>
                    <seg type="syl" n="2">guard</seg>
                    <seg type="syl" n="3">forever-</seg>
                    <seg type="syl" n="4">more.</seg>
                </l>
            </lg>
