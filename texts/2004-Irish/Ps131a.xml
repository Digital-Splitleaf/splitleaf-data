<text>
    <body>
        <div type="poem" met="6.6.8.6.">
            <lg type="verse" n="1">
                <l>
                    <seg type="syl" n="1">1. My</seg>
                    <seg type="syl" n="2">heart's</seg>
                    <seg type="syl" n="3">not</seg>
                    <seg type="syl" n="4">proud,</seg>
                    <seg type="syl" n="5">O</seg>
                    <seg type="syl" n="6">LORD,</seg>
                </l>
                <l>
                    <seg type="syl" n="1">nor</seg>
                    <seg type="syl" n="2">haug-</seg>
                    <seg type="syl" n="3">hty</seg>
                    <seg type="syl" n="4">is</seg>
                    <seg type="syl" n="5">my</seg>
                    <seg type="syl" n="6">eye;</seg>
                </l>
                <l>
                    <seg type="syl" n="1">I'm</seg>
                    <seg type="syl" n="2">not</seg>
                    <seg type="syl" n="3">con-</seg>
                    <seg type="syl" n="4">cerned</seg>
                    <seg type="syl" n="5">with</seg>
                    <seg type="syl" n="6">mat-</seg>
                    <seg type="syl" n="7">ters</seg>
                    <seg type="syl" n="8">great,</seg>
                </l>
                <l>
                    <seg type="syl" n="1">or</seg>
                    <seg type="syl" n="2">things</seg>
                    <seg type="syl" n="3">for</seg>
                    <seg type="syl" n="4">me</seg>
                    <seg type="syl" n="5">too</seg>
                    <seg type="syl" n="6">high.</seg>
                </l>
            </lg>
            <lg type="verse" n="2">
                <l>
                    <seg type="syl" n="1">2. My</seg>
                    <seg type="syl" n="2">soul</seg>
                    <seg type="syl" n="3">I've</seg>
                    <seg type="syl" n="4">stilled</seg>
                    <seg type="syl" n="5">and</seg>
                    <seg type="syl" n="6">calmed.</seg>
                </l>
                <l>
                    <seg type="syl" n="1">I,</seg>
                    <seg type="syl" n="2">like</seg>
                    <seg type="syl" n="3">a</seg>
                    <seg type="syl" n="4">weaned</seg>
                    <seg type="syl" n="5">child,</seg>
                    <seg type="syl" n="6">rest;</seg>
                </l>
                <l>
                    <seg type="syl" n="1">my</seg>
                    <seg type="syl" n="2">soul</seg>
                    <seg type="syl" n="3">is</seg>
                    <seg type="syl" n="4">like</seg>
                    <seg type="syl" n="5">a</seg>
                    <seg type="syl" n="6">weaned</seg>
                    <seg type="syl" n="7">child</seg>
                    <seg type="syl" n="8">who</seg>
                </l>
                <l>
                    <seg type="syl" n="1">lies</seg>
                    <seg type="syl" n="2">on</seg>
                    <seg type="syl" n="3">his</seg>
                    <seg type="syl" n="4">moth-</seg>
                    <seg type="syl" n="5">er's</seg>
                    <seg type="syl" n="6">breast.</seg>
                </l>
            </lg>
            <lg type="verse" n="3">
                <l>
                    <seg type="syl" n="1">3. O</seg>
                    <seg type="syl" n="2">Is-</seg>
                    <seg type="syl" n="3">r'el</seg>
                    <seg type="syl" n="4">let</seg>
                    <seg type="syl" n="5">your</seg>
                    <seg type="syl" n="6">hope</seg>
                </l>
                <l>
                    <seg type="syl" n="1">now</seg>
                    <seg type="syl" n="2">in</seg>
                    <seg type="syl" n="3">the</seg>
                    <seg type="syl" n="4">LORD</seg>
                    <seg type="syl" n="5">so</seg>
                    <seg type="syl" n="6">be,</seg>
                </l>
                <l>
                    <seg type="syl" n="1">both</seg>
                    <seg type="syl" n="2">at</seg>
                    <seg type="syl" n="3">this</seg>
                    <seg type="syl" n="4">pre-</seg>
                    <seg type="syl" n="5">sent</seg>
                    <seg type="syl" n="6">time,</seg>
                    <seg type="syl" n="7">and</seg>
                    <seg type="syl" n="8">then</seg>
                </l>
                <l>
                    <seg type="syl" n="1">in-</seg>
                    <seg type="syl" n="2">to</seg>
                    <seg type="syl" n="3">e-</seg>
                    <seg type="syl" n="4">ter-</seg>
                    <seg type="syl" n="5">ni-</seg>
                    <seg type="syl" n="6">ty.</seg>
                </l>
