                    <seg type="syl" n="2">un-</seg>
                    <seg type="syl" n="3">to</seg>
                    <seg type="syl" n="4">God,</seg>
                    <seg type="syl" n="5">How</seg>
                    <seg type="syl" n="6">ter-</seg>
                    <seg type="syl" n="7">ri-</seg>
                    <seg type="syl" n="8">ble</seg>
                </l>
                <l>
                    <seg type="syl" n="1">in</seg>
                    <seg type="syl" n="2">all</seg>
                    <seg type="syl" n="3">thy</seg>
                    <seg type="syl" n="4">works</seg>
                    <seg type="syl" n="5">art</seg>
                    <seg type="syl" n="6">thou!</seg>
                </l>
                <l>
                    <seg type="syl" n="1">Through</seg>
                    <seg type="syl" n="2">thy</seg>
                    <seg type="syl" n="3">great</seg>
                    <seg type="syl" n="4">pow'r</seg>
                    <seg type="syl" n="5">thy</seg>
                    <seg type="syl" n="6">foes</seg>
                    <seg type="syl" n="7">to</seg>
                    <seg type="syl" n="8">thee</seg>
                </l>
                <l>
                    <seg type="syl" n="1">shall</seg>
                    <seg type="syl" n="2">be</seg>
                    <seg type="syl" n="3">con-</seg>
                    <seg type="syl" n="4">strained</seg>
                    <seg type="syl" n="5">to</seg>
                    <seg type="syl" n="6">bow.</seg>
                </l>
            </lg>
            <lg type="verse" n="3">
