                    <seg type="syl" n="3">ri-</seg>
                    <seg type="syl" n="4">ous</seg>
                    <seg type="syl" n="5">make</seg>
                    <seg type="syl" n="6">his</seg>
                    <seg type="syl" n="7" cert="low">praise.</seg>
                </l>
            </lg>
            <lg type="verse" n="2">
                <l>
