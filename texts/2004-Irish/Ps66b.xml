                <l>
                    <seg type="syl" n="1">un-</seg>
                    <seg type="syl" n="2">to</seg>
                    <seg type="syl" n="3">thy</seg>
                    <seg type="syl" n="4">ho-</seg>
                    <seg type="syl" n="5">ly</seg>
                    <seg type="syl" n="6">name.</seg>
                </l>
            </lg>
            <lg type="verse" n="4">
                <l>
                    <seg type="syl" n="1">4. Come,</seg>
                    <seg type="syl" n="2">and</seg>
                    <seg type="syl" n="3">the</seg>
                    <seg type="syl" n="4">works</seg>
                    <seg type="syl" n="5">that</seg>
                    <seg type="syl" n="6">God</seg>
                    <seg type="syl" n="7">hath</seg>
                    <seg type="syl" n="8">wrought</seg>
                </l>
                <l>
                    <seg type="syl" n="1">with</seg>
                    <seg type="syl" n="2">ad-</seg>
                    <seg type="syl" n="3">mi-</seg>
                    <seg type="syl" n="4">ra-</seg>
                    <seg type="syl" n="5">tion</seg>
                    <seg type="syl" n="6">see:</seg>
                </l>
                <l>
                    <seg type="syl" n="1">in's</seg>
                    <seg type="syl" n="2">work-</seg>
                    <seg type="syl" n="3">ing</seg>
                    <seg type="syl" n="4">to</seg>
                    <seg type="syl" n="5">the</seg>
                    <seg type="syl" n="6">sons</seg>
                    <seg type="syl" n="7">of</seg>
                    <seg type="syl" n="8">men</seg>
                </l>
                <l>
                    <seg type="syl" n="1">most</seg>
                    <seg type="syl" n="2">ter-</seg>
                    <seg type="syl" n="3">ri-</seg>
                    <seg type="syl" n="4">ble</seg>
                    <seg type="syl" n="5">is</seg>
                    <seg type="syl" n="6">he.</seg>
