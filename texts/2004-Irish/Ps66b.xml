                </l>
                <l>
                    <seg type="syl" n="1">a-</seg>
                    <seg type="syl" n="2">loft</seg>
                    <seg type="syl" n="3">your</seg>
                    <seg type="syl" n="4">voic-</seg>
                    <seg type="syl" n="5">es</seg>
                    <seg type="syl" n="6">raise.</seg>
                </l>
                <l>
