<text>
    <body>
        <div type="poem" met="8.6.8.6.">
            <lg type="verse" n="1">
                <l>
                    <seg type="syl" n="1">1. All</seg>
                    <seg type="syl" n="2">lands</seg>
                    <seg type="syl" n="3">to</seg>
