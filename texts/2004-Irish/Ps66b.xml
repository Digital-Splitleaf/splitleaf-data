                    <seg type="syl" n="3">the</seg>
                    <seg type="syl" n="4">hon-</seg>
                    <seg type="syl" n="5">our</seg>
                    <seg type="syl" n="6">of</seg>
                    <seg type="syl" n="7">his</seg>
