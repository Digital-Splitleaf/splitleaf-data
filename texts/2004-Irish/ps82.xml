                    <seg type="syl" n="2">all</seg>
                    <seg type="syl" n="3">been</seg>
                    <seg type="syl" n="4">made</seg>
                    <seg type="syl" n="5">to</seg>
                    <seg type="syl" n="6">shake.</seg>
                </l>
            </lg>
            <lg type="verse" n="4">
                <l>
                    <seg type="syl" n="1">4. I</seg>
                    <seg type="syl" n="2">said</seg>
                    <seg type="syl" n="3">of</seg>
                    <seg type="syl" n="4">you</seg>
                    <seg type="syl" n="5">that</seg>
                    <seg type="syl" n="6">you</seg>
                    <seg type="syl" n="7">are</seg>
                    <seg type="syl" n="8">'gods',</seg>
                </l>
                <l>
                    <seg type="syl" n="1">all</seg>
                    <seg type="syl" n="2">sons</seg>
                    <seg type="syl" n="3">of</seg>
                    <seg type="syl" n="4">the</seg>
                    <seg type="syl" n="5">Most</seg>
                    <seg type="syl" n="6">High,</seg>
                </l>
                <l>
                    <seg type="syl" n="1">but</seg>
                    <seg type="syl" n="2">just</seg>
                    <seg type="syl" n="3">like</seg>
                    <seg type="syl" n="4">a-</seg>
                    <seg type="syl" n="5">ny</seg>
                    <seg type="syl" n="6">prince</seg>
                    <seg type="syl" n="7">you'll</seg>
                    <seg type="syl" n="8">fall;</seg>
                </l>
                <l>
                    <seg type="syl" n="1">as</seg>
                    <seg type="syl" n="2">mere</seg>
                    <seg type="syl" n="3">men</seg>
                    <seg type="syl" n="4">you</seg>
                    <seg type="syl" n="5">will</seg>
                    <seg type="syl" n="6">die.</seg>
                </l>
            </lg>
            <lg type="verse" n="5">
                <l>
                    <seg type="syl" n="1">5. 'It's</seg>
                    <seg type="syl" n="2">time</seg>
                    <seg type="syl" n="3">for</seg>
                    <seg type="syl" n="4">you</seg>
                    <seg type="syl" n="5">to</seg>
                    <seg type="syl" n="6">rise,</seg>
                    <seg type="syl" n="7">O</seg>
                    <seg type="syl" n="8">God,</seg>
                </l>
                <l>
                    <seg type="syl" n="1">and</seg>
                    <seg type="syl" n="2">judge</seg>
                    <seg type="syl" n="3">the</seg>
                    <seg type="syl" n="4">earth,'</seg>
                    <seg type="syl" n="5">say</seg>
                    <seg type="syl" n="6">we,</seg>
                </l>
                <l>
                    <seg type="syl" n="1">'For</seg>
                    <seg type="syl" n="2">you</seg>
                    <seg type="syl" n="3">and</seg>
                    <seg type="syl" n="4">you</seg>
                    <seg type="syl" n="5">a-</seg>
                    <seg type="syl" n="6">lo-</seg>
                    <seg type="syl" n="7">ne</seg>
                    <seg type="syl" n="8">pos-</seg>
                    <seg type="syl" n="9" cert="low">sess</seg>
                </l>
                <l>
                    <seg type="syl" n="1">all</seg>
                    <seg type="syl" n="2">na-</seg>
                    <seg type="syl" n="3">tions</seg>
                    <seg type="syl" n="4">that</seg>
                    <seg type="syl" n="5">there</seg>
                    <seg type="syl" n="6">be.'</seg>
                </l>
            </lg>
