<text>
    <body>
        <div type="poem" met="8.6.8.6.">
            <lg type="verse" n="1">
                <l>
                    <seg type="syl" n="1">1. To</seg>
                    <seg type="syl" n="2">judge</seg>
                    <seg type="syl" n="3">the</seg>
                    <seg type="syl" n="4">ru-</seg>
                    <seg type="syl" n="5">lers</seg>
                    <seg type="syl" n="6">o-</seg>
                    <seg type="syl" n="7">ur</seg>
                    <seg type="syl" n="8">God</seg>
                    <seg type="syl" n="9" cert="low">in</seg>
                </l>
                <l>
                    <seg type="syl" n="1">their</seg>
                    <seg type="syl" n="2">great</seg>
                    <seg type="syl" n="3">as-</seg>
                    <seg type="syl" n="4">sem-</seg>
                    <seg type="syl" n="5">bly</seg>
                    <seg type="syl" n="6">stands.</seg>
                </l>
                <l>
                    <seg type="syl" n="1">How</seg>
                    <seg type="syl" n="2">long</seg>
                    <seg type="syl" n="3">will</seg>
                    <seg type="syl" n="4">you</seg>
                    <seg type="syl" n="5">un-</seg>
                    <seg type="syl" n="6">just-</seg>
                    <seg type="syl" n="7">ly</seg>
                    <seg type="syl" n="8">judge,</seg>
                </l>
                <l>
                    <seg type="syl" n="1">and</seg>
                    <seg type="syl" n="2">fa-</seg>
                    <seg type="syl" n="3">vour</seg>
                    <seg type="syl" n="4">wic-</seg>
                    <seg type="syl" n="5">ked</seg>
                    <seg type="syl" n="6">hands?</seg>
                </l>
            </lg>
            <lg type="verse" n="2">
                <l>
                    <seg type="syl" n="1">2. De-</seg>
                    <seg type="syl" n="2">fend</seg>
                    <seg type="syl" n="3">the</seg>
                    <seg type="syl" n="4">weak</seg>
                    <seg type="syl" n="5">and</seg>
                    <seg type="syl" n="6">fa-</seg>
                    <seg type="syl" n="7">ther-</seg>
                    <seg type="syl" n="8">less;</seg>
                </l>
                <l>
                    <seg type="syl" n="1">stand</seg>
                    <seg type="syl" n="2">up</seg>
                    <seg type="syl" n="3">for</seg>
                    <seg type="syl" n="4">poor</seg>
                    <seg type="syl" n="5">op-</seg>
                    <seg type="syl" n="6">pressed.</seg>
                </l>
                <l>
                    <seg type="syl" n="1">The</seg>
                    <seg type="syl" n="2">weak</seg>
                    <seg type="syl" n="3">and</seg>
                    <seg type="syl" n="4">nee-</seg>
                    <seg type="syl" n="5">dy</seg>
                    <seg type="syl" n="6">res-</seg>
                    <seg type="syl" n="7">cue</seg>
                    <seg type="syl" n="8">from</seg>
                </l>
                <l>
                    <seg type="syl" n="1">the</seg>
                    <seg type="syl" n="2">hand</seg>
                    <seg type="syl" n="3">of</seg>
                    <seg type="syl" n="4">wic-</seg>
                    <seg type="syl" n="5">ked-</seg>
                    <seg type="syl" n="6">ness.</seg>
                </l>
            </lg>
            <lg type="verse" n="3">
                <l>
                    <seg type="syl" n="1">3. They</seg>
                    <seg type="syl" n="2">do</seg>
                    <seg type="syl" n="3">not</seg>
                    <seg type="syl" n="4">know</seg>
                    <seg type="syl" n="5">or</seg>
                    <seg type="syl" n="6">un-</seg>
                    <seg type="syl" n="7">der-</seg>
                    <seg type="syl" n="8">stand;</seg>
                </l>
                <l>
                    <seg type="syl" n="1">dark</seg>
                    <seg type="syl" n="2">is</seg>
                    <seg type="syl" n="3">the</seg>
                    <seg type="syl" n="4">path</seg>
                    <seg type="syl" n="5">they</seg>
                    <seg type="syl" n="6">take.</seg>
                </l>
                <l>
                    <seg type="syl" n="1">So,</seg>
                    <seg type="syl" n="2">the</seg>
                    <seg type="syl" n="3">foun-</seg>
                    <seg type="syl" n="4">da-</seg>
                    <seg type="syl" n="5">tions</seg>
                    <seg type="syl" n="6">of</seg>
                    <seg type="syl" n="7">the</seg>
                    <seg type="syl" n="8">earth</seg>
                </l>
