                </l>
                <l>
                    <seg type="syl" n="1">See,</seg>
                    <seg type="syl" n="2">for</seg>
                    <seg type="syl" n="3">your</seg>
                    <seg type="syl" n="4">pre-</seg>
                    <seg type="syl" n="5">cepts</seg>
                    <seg type="syl" n="6">I</seg>
                    <seg type="syl" n="7">have</seg>
                    <seg type="syl" n="8">longed;</seg>
                </l>
