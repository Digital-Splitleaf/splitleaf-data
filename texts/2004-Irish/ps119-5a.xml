                    <seg type="syl" n="5">your</seg>
                    <seg type="syl" n="6">ser-</seg>
                    <seg type="syl" n="7">vant,</seg>
                    <seg type="syl" n="8">sure,</seg>
                </l>
                <l>
                    <seg type="syl" n="1">and</seg>
                    <seg type="syl" n="2">I</seg>
                    <seg type="syl" n="3">will</seg>
                    <seg type="syl" n="4">rev-</seg>
                    <seg type="syl" n="5">er-</seg>
                    <seg type="syl" n="6">ence</seg>
                    <seg type="syl" n="7">you</seg>
                    <seg type="syl" n="8">al-</seg>
