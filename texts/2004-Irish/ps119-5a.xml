                </l>
            </lg>
            <lg type="verse" n="4">
                <l>
                    <seg type="syl" n="1">4. O</seg>
                    <seg type="syl" n="2">take</seg>
                    <seg type="syl" n="3">a-</seg>
                    <seg type="syl" n="4">way</seg>
                    <seg type="syl" n="5">my</seg>
                    <seg type="syl" n="6">feared</seg>
                    <seg type="syl" n="7">dis-</seg>
                    <seg type="syl" n="8">grace;</seg>
                </l>
                <l>
                    <seg type="syl" n="1">for</seg>
                    <seg type="syl" n="2">all</seg>
                    <seg type="syl" n="3">your</seg>
                    <seg type="syl" n="4">judg-</seg>
