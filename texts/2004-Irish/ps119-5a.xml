                    <seg type="syl" n="1">O,</seg>
                    <seg type="syl" n="2">in</seg>
                    <seg type="syl" n="3">your</seg>
                    <seg type="syl" n="4">truth,</seg>
                    <seg type="syl" n="5">give</seg>
                    <seg type="syl" n="6">life</seg>
                    <seg type="syl" n="7">to</seg>
