                    <seg type="syl" n="2">in</seg>
                    <seg type="syl" n="3">it</seg>
                    <seg type="syl" n="4">I</seg>
                    <seg type="syl" n="5">do</seg>
                    <seg type="syl" n="6">find</seg>
                    <seg type="syl" n="7">de-</seg>
                    <seg type="syl" n="8">light.</seg>
                </l>
