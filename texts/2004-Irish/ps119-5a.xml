                    <seg type="syl" n="3">my</seg>
                    <seg type="syl" n="4">heart</seg>
                    <seg type="syl" n="5">un-</seg>
                    <seg type="syl" n="6">to</seg>
                    <seg type="syl" n="7">your</seg>
                    <seg type="syl" n="8">laws,</seg>
