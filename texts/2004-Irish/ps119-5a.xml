<text>
    <body>
        <div type="poem" met="8.8.8.8.">
            <lg type="verse" n="1">
                <l>
                    <seg type="syl" n="1">1. Teach</seg>
                    <seg type="syl" n="2">me,</seg>
                    <seg type="syl" n="3">O</seg>
