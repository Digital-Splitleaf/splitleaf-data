                    <seg type="syl" n="2">tes-</seg>
                    <seg type="syl" n="3">ti-</seg>
                    <seg type="syl" n="4">mo-</seg>
                    <seg type="syl" n="5">nies</seg>
                    <seg type="syl" n="6">all</seg>
                </l>
                <l>
                    <seg type="syl" n="1">most</seg>
                    <seg type="syl" n="2">cer-</seg>
                    <seg type="syl" n="3">tain</seg>
                    <seg type="syl" n="4">are</seg>
                    <seg type="syl" n="5">and</seg>
                    <seg type="syl" n="6">sure,</seg>
                </l>
                <l>
                    <seg type="syl" n="1">and</seg>
                    <seg type="syl" n="2">ho-</seg>
                    <seg type="syl" n="3">li-</seg>
                    <seg type="syl" n="4">ness</seg>
                    <seg type="syl" n="5">a-</seg>
                    <seg type="syl" n="6">dorns</seg>
                    <seg type="syl" n="7">your</seg>
                    <seg type="syl" n="8">house,</seg>
                </l>
