                </l>
                <l>
                    <seg type="syl" n="1">en-</seg>
                    <seg type="syl" n="2">throned</seg>
                    <seg type="syl" n="3">e-</seg>
                    <seg type="syl" n="4">ter-</seg>
                    <seg type="syl" n="5">nal-</seg>
                    <seg type="syl" n="6">ly.</seg>
                </l>
            </lg>
            <lg type="verse" n="3">
                <l>
                    <seg type="syl" n="1">3. The</seg>
                    <seg type="syl" n="2">floods,</seg>
                    <seg type="syl" n="3">O</seg>
                    <seg type="syl" n="4">LORD,</seg>
                    <seg type="syl" n="5">lift</seg>
                    <seg type="syl" n="6">up,</seg>
