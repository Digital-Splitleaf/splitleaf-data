<text>
    <body>
        <div type="poem" met="6.6.8.6.">
            <lg type="verse" n="1">
                <l>
                    <seg type="syl" n="1">1. The</seg>
                    <seg type="syl" n="2">LORD</seg>
                    <seg type="syl" n="3">is</seg>
                    <seg type="syl" n="4">king;</seg>
                    <seg type="syl" n="5">he's</seg>
                    <seg type="syl" n="6">robed</seg>
                </l>
                <l>
                    <seg type="syl" n="1">with</seg>
                    <seg type="syl" n="2">ma-</seg>
                    <seg type="syl" n="3">jes-</seg>
                    <seg type="syl" n="4">ty</seg>
                    <seg type="syl" n="5">most</seg>
                    <seg type="syl" n="6">bright.</seg>
                </l>
                <l>
                    <seg type="syl" n="1">The</seg>
                    <seg type="syl" n="2">LORD,</seg>
                    <seg type="syl" n="3">he</seg>
                    <seg type="syl" n="4">has</seg>
