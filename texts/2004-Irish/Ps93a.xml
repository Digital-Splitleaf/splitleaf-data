                    <seg type="syl" n="3">hty</seg>
                    <seg type="syl" n="4">than</seg>
                    <seg type="syl" n="5">the</seg>
                    <seg type="syl" n="6">roar</seg>
                </l>
                <l>
                    <seg type="syl" n="1">of</seg>
                    <seg type="syl" n="2">ma-</seg>
                    <seg type="syl" n="3">ny</seg>
                    <seg type="syl" n="4">wa-</seg>
                    <seg type="syl" n="5">ters,</seg>
                    <seg type="syl" n="6">or</seg>
                </l>
                <l>
                    <seg type="syl" n="1">the</seg>
                    <seg type="syl" n="2">break-</seg>
                    <seg type="syl" n="3">ers</seg>
                    <seg type="syl" n="4">of</seg>
                    <seg type="syl" n="5">the</seg>
                    <seg type="syl" n="6">sea,</seg>
                    <seg type="syl" n="7">on</seg>
                    <seg type="syl" n="8">high</seg>
                </l>
                <l>
                    <seg type="syl" n="1">most</seg>
                    <seg type="syl" n="2">mig-</seg>
                    <seg type="syl" n="3">hty</seg>
                    <seg type="syl" n="4">is</seg>
                    <seg type="syl" n="5">the</seg>
                    <seg type="syl" n="6">LORD.</seg>
                </l>
            </lg>
            <lg type="verse" n="5" cert="low">
                <l>
