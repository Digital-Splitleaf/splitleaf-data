<text>
    <body>
        <div type="poem" met="6.6.8.6.">
            <lg type="verse" n="1">
                <l>
                    <seg type="syl" n="1">1. You</seg>
                    <seg type="syl" n="2">are</seg>
                    <seg type="syl" n="3">my</seg>
                    <seg type="syl" n="4">por-</seg>
                    <seg type="syl" n="5">tion,</seg>
                    <seg type="syl" n="6">LORD;</seg>
                </l>
                <l>
                    <seg type="syl" n="1">I've</seg>
                    <seg type="syl" n="2">said</seg>
                    <seg type="syl" n="3">your</seg>
                    <seg type="syl" n="4">words</seg>
                    <seg type="syl" n="5">I'd</seg>
                    <seg type="syl" n="6">heed.</seg>
                </l>
                <l>
                    <seg type="syl" n="1">With</seg>
                    <seg type="syl" n="2">all</seg>
                    <seg type="syl" n="3">my</seg>
                    <seg type="syl" n="4">heart</seg>
                    <seg type="syl" n="5">your</seg>
                    <seg type="syl" n="6">face</seg>
                    <seg type="syl" n="7">I</seg>
                    <seg type="syl" n="8">sought;</seg>
                </l>
                <l>
                    <seg type="syl" n="1">your</seg>
                    <seg type="syl" n="2">pro-</seg>
                    <seg type="syl" n="3">mi-</seg>
                    <seg type="syl" n="4">sed</seg>
                    <seg type="syl" n="5">love</seg>
                    <seg type="syl" n="6">I</seg>
                    <seg type="syl" n="7" cert="low">need.</seg>
                </l>
            </lg>
            <lg type="verse" n="2">
                <l>
                    <seg type="syl" n="1">2. I</seg>
                    <seg type="syl" n="2">thought</seg>
                    <seg type="syl" n="3">a-</seg>
                    <seg type="syl" n="4">bout</seg>
                    <seg type="syl" n="5">my</seg>
                    <seg type="syl" n="6">ways,</seg>
                </l>
                <l>
                    <seg type="syl" n="1">to</seg>
                    <seg type="syl" n="2">your</seg>
                    <seg type="syl" n="3">laws</seg>
                    <seg type="syl" n="4">turned</seg>
                    <seg type="syl" n="5">my</seg>
                    <seg type="syl" n="6">feet.</seg>
                </l>
                <l>
                    <seg type="syl" n="1">I</seg>
                    <seg type="syl" n="2">hur-</seg>
                    <seg type="syl" n="3">ried</seg>
                    <seg type="syl" n="4">and</seg>
                    <seg type="syl" n="5">did</seg>
                    <seg type="syl" n="6">not</seg>
                    <seg type="syl" n="7">de-</seg>
                    <seg type="syl" n="8">lay</seg>
                </l>
                <l>
                    <seg type="syl" n="1">all</seg>
                    <seg type="syl" n="2">your</seg>
                    <seg type="syl" n="3">com-</seg>
                    <seg type="syl" n="4">mands</seg>
                    <seg type="syl" n="5">to</seg>
                    <seg type="syl" n="6">keep.</seg>
                </l>
            </lg>
            <lg type="verse" n="3">
                <l>
                    <seg type="syl" n="1">3. Though</seg>
                    <seg type="syl" n="2">wic-</seg>
                    <seg type="syl" n="3">ked</seg>
                    <seg type="syl" n="4">men</seg>
                    <seg type="syl" n="5">me</seg>
                    <seg type="syl" n="6">bound,</seg>
                </l>
                <l>
                    <seg type="syl" n="1">I</seg>
                    <seg type="syl" n="2">kept</seg>
                    <seg type="syl" n="3">your</seg>
                    <seg type="syl" n="4">law</seg>
                    <seg type="syl" n="5">in</seg>
                    <seg type="syl" n="6">view.</seg>
                </l>
                <l>
                    <seg type="syl" n="1">I'll</seg>
                    <seg type="syl" n="2">rise</seg>
                    <seg type="syl" n="3">at</seg>
                    <seg type="syl" n="4">mid-</seg>
                    <seg type="syl" n="5">night,</seg>
                    <seg type="syl" n="6">give</seg>
                    <seg type="syl" n="7">you</seg>
                    <seg type="syl" n="8">thanks,</seg>
                </l>
                <l>
                    <seg type="syl" n="1">for</seg>
                    <seg type="syl" n="2">all</seg>
                    <seg type="syl" n="3">your</seg>
                    <seg type="syl" n="4">judg-</seg>
                    <seg type="syl" n="5">ments</seg>
                    <seg type="syl" n="6">true.</seg>
                </l>
            </lg>
            <lg type="verse" n="4">
                <l>
                    <seg type="syl" n="1">4. I've</seg>
                    <seg type="syl" n="2">joined</seg>
                    <seg type="syl" n="3">those</seg>
                    <seg type="syl" n="4">who</seg>
                    <seg type="syl" n="5">fear</seg>
                    <seg type="syl" n="6">you,</seg>
                </l>
                <l>
                    <seg type="syl" n="1">your</seg>
                    <seg type="syl" n="2">pre-</seg>
                    <seg type="syl" n="3">cepts</seg>
                    <seg type="syl" n="4">who</seg>
                    <seg type="syl" n="5">o-</seg>
                    <seg type="syl" n="6">bey.</seg>
                </l>
                <l>
                    <seg type="syl" n="1">Your</seg>
                    <seg type="syl" n="2">stead-</seg>
                    <seg type="syl" n="3">fast</seg>
                    <seg type="syl" n="4">love,</seg>
                    <seg type="syl" n="5">LORD,</seg>
                    <seg type="syl" n="6">fills</seg>
                    <seg type="syl" n="7">the</seg>
                    <seg type="syl" n="8">earth;</seg>
                </l>
                <l>
                    <seg type="syl" n="1">teach</seg>
                    <seg type="syl" n="2">me</seg>
                    <seg type="syl" n="3">your</seg>
                    <seg type="syl" n="4">laws,</seg>
                    <seg type="syl" n="5">I</seg>
                    <seg type="syl" n="6">pray.</seg>
                </l>
            </lg>
